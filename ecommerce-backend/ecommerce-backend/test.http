###############################################
# ADMIN ROUTES
###############################################
### Admin Login
POST http://localhost:5000/api/users/login
Content-Type: application/json

{
  "email": "sana.ak889@gmail.com",
  "password": "Titanic3#"
}


# --- After sending this, copy the token from the response ---
# --- Replace <ADMIN_TOKEN> in the requests below with your token ---

### Create Product (Admin Only)
POST http://localhost:5000/api/products
Content-Type: application/json
Authorization: Bearer <ADMIN_TOKEN>

{
  "name": "Cool T-Shirt",
  "description": "High quality cotton t-shirt",
  "price": 25,
  "countInStock": 50,
  "image": "/images/tshirt.png"
}

### Get All Orders (Admin Only)
GET http://localhost:5000/api/orders
Authorization: Bearer <ADMIN_TOKEN>

### Mark Order as Delivered (Admin Only)
PUT http://localhost:5000/api/orders/<ORDER_ID>/deliver
Authorization: Bearer <ADMIN_TOKEN>

###############################################
# USER ROUTES
###############################################

### Register User
POST http://localhost:5000/api/users/register
Content-Type: application/json

{
  "name": "John Doe",
  "email": "john@example.com",
  "password": "John123#"
}

### Login User
POST http://localhost:5000/api/users/login
Content-Type: application/json

{
  "email": "john@example.com",
  "password": "John123#"
}

### Create Order (Customer)
POST http://localhost:5000/api/orders
Content-Type: application/json
Authorization: Bearer <USER_TOKEN>

{
  "orderItems": [
    {
      "product": "<PRODUCT_ID>",
      "name": "Cool T-Shirt",
      "qty": 2,
      "price": 25
    }
  ],
  "shippingAddress": {
    "address": "123 Main St",
    "city": "Karachi",
    "postalCode": "75500",
    "country": "Pakistan"
  },
  "paymentMethod": "Cash on Delivery",
  "totalPrice": 50
}

### Get My Orders (Customer)
GET http://localhost:5000/api/orders/myorders
Authorization: Bearer <USER_TOKEN>
